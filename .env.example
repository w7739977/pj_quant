# =============================================================
# pj_quant 环境变量配置模板
#
# 用法:
#   1. cp .env.example .env
#   2. 编辑 .env 填入下列各 key
#   3. config/settings.py 启动时自动加载（无需手动 source）
#
# 备注:
#   - .env 已在 .gitignore，不会被提交
#   - 也可以用 systemd EnvironmentFile=/opt/pj_quant/.env
# =============================================================

# === 必填: Tushare 数据源 ===
# 申请: https://tushare.pro/register
# 行情/估值/财务/行业 数据全部依赖此 token
TUSHARE_TOKEN=

# === 必填: PushPlus 微信推送 ===
# 申请: https://www.pushplus.plus/
PUSHPLUS_TOKEN=

# 可选: 多账号同时推送（comma 分隔）
# 优先于 PUSHPLUS_TOKEN，未设置时 fallback 到单账号
# 例: PUSHPLUS_TOKENS=token1,token2,token3
PUSHPLUS_TOKENS=

# === 必填: LLM 主源 DeepSeek ===
# 申请: https://platform.deepseek.com/api_keys
# 用于推送中的 AI 研判 / 市场情绪深度分析（不影响选股 alpha）
DEEPSEEK_API_KEY=

# === 可选: LLM 备源 GLM-4-flash（智谱 AI，免费）===
# 申请: https://open.bigmodel.cn/
# DeepSeek 失败时自动 fallback。两个都失败时推送跳过 AI 段落
GLM_API_KEY=

# === 可选: Web 持仓同步服务 token ===
# server.py 启动后访问地址中的认证 token
# 默认: pj_quant_2026
WEB_TOKEN=pj_quant_2026
